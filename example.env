# Copy to .env for local development. In production, set real env vars
# (they always win over .env). Never commit a filled-in .env.

# PocketBase
CONFIG_PATH=config.json
PB_SUPERUSER_EMAIL=
PB_SUPERUSER_PASSWORD=

# Google OAuth2 sign-in (optional). Create an OAuth client in Google Cloud
# Console (APIs & Services → Credentials → OAuth client ID → Web application)
# and set the Authorized redirect URI to <app_url>/auth/google/callback.
# When either value is empty the "Continue with Google" button is hidden and
# the /auth/google routes are disabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Lemon Squeezy (payment processing). When unset, the pricing page still
# renders but checkout returns "not configured".
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_STORE_ID=

# Lemon Squeezy variant IDs per tier (the numeric variant id of the product).
# LEMON_SQUEEZY_PRODUCT_STANDARD=
# LEMON_SQUEEZY_PRODUCT_PREMIUM=

# Pricing experiment variants, toggled by PostHog feature flags
# ("pricing-higher" / "pricing-lower"). Only needed once you define
# pricing_variants in config.json and actually run a price test.
# LEMON_SQUEEZY_PRODUCT_HIGHER_STANDARD=
# LEMON_SQUEEZY_PRODUCT_HIGHER_PREMIUM=
# LEMON_SQUEEZY_PRODUCT_LOWER_STANDARD=
# LEMON_SQUEEZY_PRODUCT_LOWER_PREMIUM=

# PostHog product analytics + session replay. The `phc_...` project key is a
# public client-side token and can also live in config.json; set these to
# override per-environment (e.g. a separate project for staging).
# POSTHOG_KEY=
# POSTHOG_HOST=https://eu.i.posthog.com

# S3 / Object Storage (set s3.enabled: true in config.json to activate)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=eu-central-1
S3_ENDPOINT=
S3_BUCKET=
